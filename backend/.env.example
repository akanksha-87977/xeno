# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/transaction_validator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=transaction_validator

# JWT
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API
API_V1_STR=/api/v1
PROJECT_NAME=Global Transaction Validator

# File Upload
MAX_FILE_SIZE=104857600
UPLOAD_DIR=./uploads
ALLOWED_EXTENSIONS=.csv,.xlsx,.xls

# Validation
CHUNK_SIZE=50000
MAX_ROWS_PER_FILE=100000

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","https://yourdomain.vercel.app"]

# Redis (for rate limiting)
REDIS_URL=redis://localhost:6379/0

# Environment
ENVIRONMENT=development